# CTFGenerator deploy env reference (M18 18a) -- copy to deploy/.env and edit.
#
#   cp deploy/.env.example deploy/.env    # deploy/.env is gitignored
#
# ALL values here are PLACEHOLDERS -- NEVER commit real secrets. deploy/.env (the
# real file) is gitignored. The compose file interpolates these; no secret is
# baked into any committed file.

# --- Postgres (the reference compose db) -------------------------------------
POSTGRES_USER=ctfgen                       # db role
POSTGRES_PASSWORD=CHANGE_ME_db_password    # PLACEHOLDER -- set a strong secret
POSTGRES_DB=ctfgen                         # db name

# --- Control-plane database DSN ----------------------------------------------
# The API/worker-gateway/CLI/admin all read the DSN from this ONE var; it is
# never stored in alembic.ini. In the reference compose it is assembled from the
# POSTGRES_* values above, so you usually only set those. Set this directly when
# pointing at an external/managed database:
# CTFGEN_DATABASE_URL=postgresql+psycopg://USER:PASSWORD@HOST:5432/DBNAME

# --- Artifact store ----------------------------------------------------------
CTFGEN_ARTIFACT_ROOT=/var/lib/ctfgen/artifacts   # content-addressed store root

# --- API runtime knobs -------------------------------------------------------
CTFGEN_API_RATE_LIMIT=1        # 1=on (recommended), 0=off
CTFGEN_API_TRUSTED_PROXY=1     # 1 ONLY behind a proxy that owns X-Forwarded-For
CTFGEN_LOG_FORMAT=json         # json (prod) | text (dev)
CTFGEN_LOG_LEVEL=INFO          # INFO | DEBUG | WARNING

# --- Organizer web UI --------------------------------------------------------
CTFGEN_WEB_ENABLED=1                       # 1=serve /app UI, 0=API-only
CTFGEN_WEB_CSRF_SECRET=CHANGE_ME_csrf_secret   # PLACEHOLDER -- random 32+ bytes
# CTFGEN_WEB_COOKIE_INSECURE=0             # 1 ONLY for a non-TLS local demo

# --- First admin bootstrap (ONE-TIME, run by hand, NOT auto-run) -------------
# After first `up`, seed the initial admin ONCE:
#   docker compose exec api ctfgen-admin bootstrap-admin --email you@example.com
# It reads the password from this env var (PLACEHOLDER here):
CTFGEN_BOOTSTRAP_ADMIN_PASSWORD=CHANGE_ME_admin_password

# --- OIDC federated login (OPTIONAL -- leave blank to disable) ---------------
CTFGEN_OIDC_ISSUER=                        # e.g. https://idp.example.com
CTFGEN_OIDC_CLIENT_ID=
CTFGEN_OIDC_CLIENT_SECRET=CHANGE_ME_oidc_client_secret   # PLACEHOLDER
CTFGEN_OIDC_REDIRECT_URI=                  # e.g. https://ctf.example.com/api/v1/auth/oidc/callback
# CTFGEN_OIDC_ALLOWED_DOMAINS=example.com
# CTFGEN_OIDC_AUTO_PROVISION=0
# CTFGEN_OIDC_SCOPES=openid email profile

# --- Reverse proxy -----------------------------------------------------------
PUBLIC_DOMAIN=localhost                     # the TLS hostname Caddy serves

# --- Worker (runs on a SEPARATE host; shown for reference, NOT in this compose)
# CTFGEN_WORKER_TRANSPORT=http
# CTFGEN_WORKER_CONTROL_PLANE_URL=https://ctf.example.com   # worker-gateway URL
# CTFGEN_WORKER_TOKEN=CHANGE_ME_worker_scoped_token         # PLACEHOLDER
# CTFGEN_WORKER_NAME=worker-1
# CTFGEN_WORKER_LEASE_SECONDS=60
